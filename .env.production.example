# === Logging ===
LOG_LEVEL=WARNING

# === Database (Render PostgreSQL - вставьте ваш URL) ===
# Получите в панели Render → PostgreSQL → Internal Database URL
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech:5432/corpknow

# === JWT Auth (сгенерируйте новый ключ для продакшена) ===
SECRET_KEY=your-super-secret-production-key-here-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === ChromaDB (в том же docker-compose с бэкендом на Render) ===
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# === LLM (Cloudflare Tunnel к вашему ПК с Windows) ===
# Запустите: cloudflared tunnel --url http://localhost:11434
# Скопируйте URL из вывода, например:
OLLAMA_HOST=https://ollama-abc123.trycloudflare.com
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2:3b

# === Frontend (Vercel - ваш домен) ===
VITE_API_URL=https://corpknow-backend.onrender.com

# === App Settings (продакшен) ===
ENVIRONMENT=production
DEBUG=False
CORS_ORIGINS=https://corpknow-frontend.vercel.app